# =====================================================
# secrets.toml 예시 파일
# =====================================================
# 이 파일을 같은 폴더에 'secrets.toml' 이름으로 복사한 뒤
# 아래 OPENAI_API_KEY 값을 본인 API 키로 채워 사용하세요.
#
# (API 키가 없어도 프로그램은 정상 동작합니다 - 규칙 기반 분석으로 자동 동작)
#
# Streamlit Cloud 배포 시:
#   대시보드 → Settings → Secrets 메뉴에 동일한 내용을 입력하면 됩니다.
# =====================================================

OPENAI_API_KEY = "sk-여기에_본인_API_키_입력"


# Supabase DB 연결 정보
SUPABASE_URL = "https://여기에_프로젝트_URL.supabase.co"
SUPABASE_KEY = "여기에_anon_public_key_입력"
